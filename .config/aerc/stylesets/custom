# Base reset
*.default=true
*.normal=true

# Global selected style
*.selected.reverse=true
*.selected.bold=true

# Status line
statusline_default.bg=0
statusline_default.fg=11
statusline_error.fg=9
statusline_error.bold=true

# Message list
msglist_default.fg=7
msglist_unread.fg=11
msglist_unread.bold=true
msglist_read.fg=8
msglist_flagged.fg=9
msglist_answered.fg=10
